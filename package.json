{
  "name": "fretboard-filter",
  "private": true,
  "version": "0.1.0",
  "description": "Fretboard Filter monorepo",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "corepack pnpm --filter app dev:desktop",
    "dev:web": "corepack pnpm --filter app dev",
    "build:web": "corepack pnpm --filter app build:web",
    "preview:web": "corepack pnpm --filter app preview:web",
    "build": "corepack pnpm -r build",
    "test:core": "corepack pnpm --filter core test",
    "test:core:coverage": "corepack pnpm --filter core test:coverage"
  }
}
