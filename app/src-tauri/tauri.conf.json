{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fretboard Filter",
  "version": "0.1.0",
  "identifier": "com.nathanturner.fretboardfilter",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Fretboard Filter",
        "width": 1280,
        "height": 880,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
